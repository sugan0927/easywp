
# easyinstallToolsStartBlackhole
server {
	listen <port> ssl reuseport default_server;
	listen [::]:<port> ssl reuseport default_server;
	listen <port> quic reuseport default_server;
	listen [::]:<port> quic reuseport default_server;

	ssl_certificate /etc/ssl/certs/easyinstall-blackhole.crt.pem;
	ssl_certificate_key /etc/ssl/private/easyinstall-blackhole.key.pem;
	error_page 497  https://$host:$server_port$request_uri;
	
	return 444;
}
# easyinstallToolsEndBlackhole